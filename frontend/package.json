{
  "name": "retrospekt-frontend",
  "version": "1.33.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "tsx scripts/parse-changelog.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "pretypecheck": "tsx scripts/parse-changelog.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ct": "playwright test -c playwright-ct.config.ts",
    "test:wtr": "web-test-runner"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "d3": "^7.9.0"
  },
  "nyc": {
    "lines": 94,
    "statements": 94,
    "branches": 94,
    "functions": 94
  },
  "devDependencies": {
    "@open-wc/testing": "^4.0.0",
    "@playwright/test": "^1.60.0",
    "@sentry/browser": "^10.55.0",
    "@types/d3": "^7.4.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "@web/dev-server-esbuild": "^1.0.5",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-playwright": "^0.11.1",
    "eslint": "^10.4.1",
    "jsdom": "^29.1.1",
    "lit": "^3.3.3",
    "nyc": "^18.0.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vite-plugin-istanbul": "^9.0.1",
    "vitest": "^4.1.7"
  }
}
